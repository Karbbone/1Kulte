meta {
  name: Login
  type: http
  seq: 4
}

post {
  url: {{host}}/users/login
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
      "email": "john.doe@example.com",
      "password": "testtest"
  }
}

script:post-response {
  const token = res.body?.token;
  
  if (token) {
    bru.setVar("jwt", token);
    bru.setEnvVar("jwt", token);
  }
}
